   "source": [
    "# ── الخلية 4: تشغيل الداشبورد ──\n",
    "from pyngrok import ngrok\n",
    "import subprocess, time\n",
    "\n",
    "# شغّل streamlit في الخلفية\n",
    "proc = subprocess.Popen(\n",
    "    ['streamlit', 'run', 'raneen_dashboard.py', '--server.port=8501', '--server.headless=true'],\n",
    "    stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL\n",
    ")\n",
    "\n",
    "time.sleep(4)\n",
    "\n",
    "# افتح نفق عام\n",
    "public_url = ngrok.connect(8501)\n",
    "print('=' * 50)\n",
    "print('✅ الداشبورد شغّال!')\n",
    "print(f'🔗 افتح الرابط ده في المتصفح:')\n",
    "print(f'   {public_url}')\n",
    "print('=' * 50)\n",
    "print('⚠️  الرابط شغّال طول ما Colab مفتوح')"
   ],
   "execution_count": null,
   "outputs": []
  }
 ]
